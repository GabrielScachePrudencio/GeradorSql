<Window x:Class="GeradorSql_Liffe.SQLGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SQL Generator — Procedimentos"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        Background="#0f1117"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- ── Scrollbar slim dark ── -->
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="Background" Value="#2e3250"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── DatePicker ── -->
        <Style TargetType="DatePicker">
            <Setter Property="Background"       Value="#1a1d27"/>
            <Setter Property="Foreground"       Value="#e8eaf6"/>
            <Setter Property="BorderBrush"      Value="#2e3250"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Padding"          Value="4"/>
        </Style>

        <!-- ── DataGrid ── -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"            Value="#20243a"/>
            <Setter Property="Foreground"            Value="#e8eaf6"/>
            <Setter Property="BorderThickness"       Value="0"/>
            <Setter Property="GridLinesVisibility"   Value="None"/>
            <Setter Property="RowBackground"         Value="#20243a"/>
            <Setter Property="AlternatingRowBackground" Value="#1a1d27"/>
            <Setter Property="HeadersVisibility"     Value="Column"/>
            <Setter Property="CanUserAddRows"        Value="False"/>
            <Setter Property="IsReadOnly"            Value="True"/>
            <Setter Property="SelectionMode"         Value="Single"/>
            <Setter Property="AutoGenerateColumns"   Value="False"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility"   Value="Auto"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"       Value="#1a1d27"/>
            <Setter Property="Foreground"       Value="#8b92b8"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Padding"          Value="8,6"/>
            <Setter Property="BorderBrush"      Value="#2e3250"/>
            <Setter Property="BorderThickness"  Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground"       Value="#e8eaf6"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Padding"          Value="8,4"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2a2f4a"/>
                    <Setter Property="Foreground" Value="#e8eaf6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2a2f4a"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2a2f4a"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Button base ── -->
        <Style x:Key="UtilBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="#e8eaf6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="20,9"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Copy button inside card ── -->
        <Style x:Key="CopyBtn" TargetType="Button">
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="10,3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════
         ROOT
    ══════════════════════════════════════════════════════════ -->
    <Border Padding="20" Background="#0f1117">
        <DockPanel LastChildFill="True">

            <!-- ── HEADER ── -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="SQL Generator"
                               Foreground="#e8eaf6" FontSize="22" FontWeight="Bold"
                               FontFamily="Consolas, Courier New"/>
                    <TextBlock Text="Procedimentos · Convênios · Produção"
                               Foreground="#4a5078" FontSize="12"/>
                </StackPanel>

                <Border Grid.Column="1" VerticalAlignment="Center"
                         CornerRadius="20" Padding="10,3">
                    <!-- #7c6af722 approx -->
                    <Border.Background>
                        <SolidColorBrush Color="#7c6af7" Opacity="0.13"/>
                    </Border.Background>
                    <TextBlock Text="v2.0" Foreground="#7c6af7" FontSize="11"/>
                </Border>
            </Grid>

            <!-- ── SEPARATOR ── -->
            <Border DockPanel.Dock="Top" Height="1" Background="#2e3250" Margin="0,0,0,14"/>

            <!-- ══════════════════════════════════════════
                 BODY  (left panel + center)
            ══════════════════════════════════════════ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340" MinWidth="280"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- ────────────────────────────────────
                     LEFT PANEL
                ──────────────────────────────────── -->
                <StackPanel Grid.Column="0">

                    <!-- Card: Filtro -->
                    <Border Background="#20243a" BorderBrush="#2e3250" BorderThickness="1"
                            CornerRadius="12" Padding="16" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="FILTRO DE PERÍODO"
                                       Foreground="#4a5078" FontSize="10" FontWeight="Bold"
                                       Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Início" Foreground="#8b92b8" FontSize="11" Margin="0,0,0,4"/>
                                    <DatePicker x:Name="dataInicio"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Fim" Foreground="#8b92b8" FontSize="11" Margin="0,0,0,4"/>
                                    <DatePicker x:Name="dataFim"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Card: Gerar SQL -->
                    <Border Background="#20243a" BorderBrush="#2e3250" BorderThickness="1"
                            CornerRadius="12" Padding="16" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="GERAR SQL"
                                       Foreground="#4a5078" FontSize="10" FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="btnUpdateProducao"
                                        Grid.Column="0"
                                        Content="▲  UPDATE PRODUÇÃO"
                                        Foreground="#22c55e"
                                        BorderBrush="#3322c55e"
                                        Cursor="Hand" FontSize="12" FontWeight="Bold"
                                        Padding="12,10"
                                        Click="BtnUpdateProducao_Click">
                                    <Button.Background>
                                        <SolidColorBrush Color="#22c55e" Opacity="0.13"/>
                                    </Button.Background>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="brd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="#4022c55e" BorderThickness="1"
                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="brd" Property="Background">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="#22c55e" Opacity="0.27"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button x:Name="btnInsertValor"
                                        Grid.Column="2"
                                        Content="＋  INSERT VALOR"
                                        Foreground="#3b82f6"
                                        Cursor="Hand" FontSize="12" FontWeight="Bold"
                                        Padding="12,10"
                                        Click="BtnInsertValor_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="brd"
                                                    Background="#223b82f6" BorderBrush="#403b82f6"
                                                    BorderThickness="1" CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="brd" Property="Background" Value="#443b82f6"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="btnUpdateValor"
                                        Grid.Column="0"
                                        Content="⟳  UPDATE VALOR"
                                        Foreground="#f59e0b"
                                        Cursor="Hand" FontSize="12" FontWeight="Bold"
                                        Padding="12,10"
                                        Click="BtnUpdateValor_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="brd"
                                                    Background="#22f59e0b" BorderBrush="#40f59e0b"
                                                    BorderThickness="1" CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="brd" Property="Background" Value="#44f59e0b"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button x:Name="btnInsertProc"
                                        Grid.Column="2"
                                        Content="⊕  INSERT PROC."
                                        Foreground="#a855f7"
                                        Cursor="Hand" FontSize="12" FontWeight="Bold"
                                        Padding="12,10"
                                        Click="BtnInsertProc_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="brd"
                                                    Background="#22a855f7" BorderBrush="#40a855f7"
                                                    BorderThickness="1" CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="brd" Property="Background" Value="#44a855f7"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Background="#20243a" BorderBrush="#2e3250" BorderThickness="1"
                            CornerRadius="12" Padding="16">
                        <StackPanel>
                            <TextBlock Text="ARQUIVOS"
                                       Foreground="#4a5078" FontSize="10" FontWeight="Bold"
                                       Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Abrir CSV"
                                        Background="#374151"
                                        Style="{StaticResource UtilBtn}"
                                        Margin="0,0,12,0"
                                        Click="BtnAbrirCSV_Click"/>
                                <Button Content="Salvar SQL"
                                        Background="#7c6af7"
                                        Style="{StaticResource UtilBtn}"
                                        Click="BtnSalvarSQL_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Card: Arquivos -->

                </StackPanel>

                <!-- ────────────────────────────────────
                     CENTER PANEL
                ──────────────────────────────────── -->
                <DockPanel Grid.Column="2" LastChildFill="True">

                    <!-- Tabela -->
                    <Border DockPanel.Dock="Top"
                            Background="#20243a" BorderBrush="#2e3250" BorderThickness="1"
                            CornerRadius="10" MaxHeight="220" MinHeight="140"
                            Margin="0,0,0,14" ClipToBounds="True">
                        <DataGrid x:Name="tabela">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="idProcedimento" Binding="{Binding IdProcedimento}" Width="*"/>
                                <DataGridTextColumn Header="Procedimento"   Binding="{Binding Nome}"           Width="*"/>
                                <DataGridTextColumn Header="Tuss"           Binding="{Binding Tuss}"           Width="*"/>
                                <DataGridTextColumn Header="idConvenio"     Binding="{Binding IdConvenio}"     Width="*"/>
                                <DataGridTextColumn Header="Convênio"       Binding="{Binding Convenio}"       Width="*"/>
                                <DataGridTextColumn Header="Valor Antigo"   Binding="{Binding ValorAntigo}"    Width="*"/>
                                <DataGridTextColumn Header="Valor Novo"     Binding="{Binding ValorNovo}"      Width="*"/>
                                <DataGridTextColumn Header="Data Cadastro"  Binding="{Binding DataCadastro}"   Width="*"/>
                                <DataGridTextColumn Header="Ativo"          Binding="{Binding Ativo}"          Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- SQL cards wrapper -->
                    <Border Background="#090c14" BorderBrush="#2e3250" BorderThickness="1"
                            CornerRadius="12" Padding="14">
                        <DockPanel LastChildFill="True">

                            <!-- Header SQL -->
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="SQL GERADO"
                                           Foreground="#4a5078" FontSize="10" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblTotalCards"
                                           Grid.Column="1"
                                           Text="0 blocos"
                                           Foreground="#4a5078" FontSize="11"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Scroll com cards -->
                            <ScrollViewer x:Name="scrollCards"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Background="#090c14">
                                <StackPanel x:Name="painelCards" Margin="0,0,6,0">
                                    <TextBlock x:Name="emptyLabel"
                                               Text="Nenhum SQL gerado. Carregue um CSV e clique em uma ação."
                                               Foreground="#4a5078" FontSize="13"
                                               Margin="4"/>
                                </StackPanel>
                            </ScrollViewer>

                        </DockPanel>
                    </Border>

                </DockPanel>
            </Grid>
        </DockPanel>
    </Border>
</Window>
